void main() {
  print("1. Кружка и Человек");
  Mug mug = Mug("Чай");
  Person person = Person("Анна");
  person.drink(mug);

  print("\n2. Шкаф");
  Closet closet = Closet();
  closet.put("Верх", "Шапка");
  closet.put("Низ", "Обувь");
  print(closet.get("Верх"));
  print(closet.get("Низ"));

  print("\n3. Гриф");
  Barbell bar = Barbell(50);
  bar.addPlate(10);
  bar.addPlate(20);
  bar.addPlate(30);
  print("Вес: ${bar.currentWeight}");

  print("\n4. Конвертер валют");
  CurrencyConverter conv = CurrencyConverter({"USD": 1, "RUB": 90, "EUR": 0.9});
  print(conv.convert(10, "USD", "RUB"));
  print(conv.convert(90, "RUB", "EUR"));

  print("\n5. Гараж (дженерики)");
  Garage<String> garage = Garage<String>();
  garage.park("Машина");
  garage.park("Мотоцикл");
  print(garage.unpark());
  print(garage.unpark());

  print("\n6. Перегрузка операторов");
