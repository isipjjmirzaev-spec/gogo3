import os
import pickle
from abc import ABC, abstractmethod

SAVE_FILE = "library_save.pkl"


class Person(ABC):
    def __init__(self, name):
        self._name = name

    def get_name(self):
        return self._name

    @abstractmethod
    def get_role(self):
        pass


class Librarian(Person):
    def __init__(self, name, password):
        super().__init__(name)
        self.__password = password

    def check_password(self, password):
        return self.__password == password

    def get_role(self):
        return "Библиотекарь"


class User(Person):
    def __init__(self, name):
        super().__init__(name)
        self.__borrowed_books = []

    def get_role(self):
        return "Пользователь"

    def add_book(self, title):
        self.__borrowed_books.append(title)

    def remove_book(self, title):
        if title in self.__borrowed_books:
            self.__borrowed_books.remove(title)

    def get_borrowed_books(self):
        return self.__borrowed_books.copy()


class Book:
    def __init__(self, title, author):
        self.__title = title
        self.__author = author
        self.__available = True

    def get_title(self):
        return self.__title

    def get_author(self):
        return self.__author

    def is_available(self):
        return self.__available

    def mark_taken(self):
        self.__available = False

    def mark_returned(self):
        self.__available = True

    def __str__(self):
        status = "доступна" if self.__available else "выдана"
        return f"{self.__title} ({self.__author}) - {status}"


class Library:
    def __init__(self):
        self.__books = []
        self.__users = []
        self.__current_user = None
        self.__admin = Librarian("admin", "123")

        loaded = self.__load_data()
        if not loaded:
            self.__books.append(Book("Война и мир", "Толстой"))
            self.__books.append(Book("1984", "Оруэлл"))

    def __load_data(self):
        if not os.path.exists(SAVE_FILE):
            return False

        with open(SAVE_FILE, "rb") as f:
            snapshot = pickle.load(f)

        self.__books = snapshot.get("books", [])
        self.__users = snapshot.get("users", [])
        return True

    def __save_data(self):
        snapshot = {
            "books": self.__books,
            "users": self.__users,
        }
        with open(SAVE_FILE, "wb") as f:
            pickle.dump(snapshot, f)
        print("Данные сохранены")

    def login_admin(self, name, password):
        if name == self.__admin.get_name() and self.__admin.check_password(password):
            self.__current_user = self.__admin
            print(f"Вход выполнен как Библиотекарь")
            return True
        print("Неверный логин или пароль")
        return False

    def login_user(self, name):
        for user in self.__users:
            if user.get_name() == name:
                self.__current_user = user
                print(f"Добро пожаловать, {name}")
                return True
        new_user = User(name)
        self.__users.append(new_user)
        self.__current_user = new_user
        print(f"Вы зарегистрированы и вошли, {name}")
        return True

    def logout(self):
        self.__save_data()
        self.__current_user = None
        print("Вы вышли из системы")

    def add_book(self):
        title = input("Название книги: ")
        author = input("Автор: ")
        self.__books.append(Book(title, author))
        print("Книга добавлена")

    def remove_book(self):
        title = input("Название книги для удаления: ")
        for book in self.__books:
            if book.get_title().lower() == title.lower():
                if not book.is_available():
                    print("Нельзя удалить выданную книгу")
                    return
                self.__books.remove(book)
                print("Книга удалена")
                return
        print("Книга не найдена")

    def show_all_books(self):
        print("\nСписок всех книг")
        if not self.__books:
            print("Пусто")
            return
        for i, book in enumerate(self.__books, 1):
            print(f"{i}. {book}")

    def show_all_users(self):
        print("\nСписок пользователей")
        if not self.__users:
            print("Пусто")
            return
        for i, user in enumerate(self.__users, 1):
            print(f"{i}. {user.get_name()}")

    def show_available_books(self):
        print("\nДоступные книги")
        found = False
        for book in self.__books:
            if book.is_available():
                print(f"- {book.get_title()} ({book.get_author()})")
                found = True
        if not found:
            print("Нет доступных книг")

    def take_book(self):
        title = input("Введите название книги: ")
        for book in self.__books:
            if book.get_title().lower() == title.lower():
                if book.is_available():
                    book.mark_taken()
                    self.__current_user.add_book(book.get_title())
                    print(f"Вы взяли '{book.get_title()}'")
                else:
                    print("Книга уже выдана другому")
                return
        print("Книга не найдена")

    def return_book(self):
        borrowed = self.__current_user.get_borrowed_books()
        if not borrowed:
            print("У вас нет книг")
            return

        print("Ваши книги:")
        for i, title in enumerate(borrowed, 1):
            print(f"{i}. {title}")

        num = input("Введите номер книги для возврата: ")
        if num.isdigit() and 0 < int(num) <= len(borrowed):
            title = borrowed[int(num) - 1]
            self.__current_user.remove_book(title)
            for book in self.__books:
                if book.get_title().lower() == title.lower():
                    book.mark_returned()
                    break
            print("Книга возвращена")
        else:
            print("Отмена")

    def show_my_books(self):
        print("\nМои книги")
        borrowed = self.__current_user.get_borrowed_books()
        if not borrowed:
            print("У вас нет книг")
        else:
            for title in borrowed:
                print(f"- {title}")

    def run(self):
        print("БИБЛИОТЕКА")
        while True:
            print("\nМЕНЮ")
            if self.__current_user:
                print(f"Вы: {self.__current_user.get_role()} ({self.__current_user.get_name()})")

                if isinstance(self.__current_user, Librarian):
                    print("1. Добавить книгу")
                    print("2. Удалить книгу")
                    print("3. Показать все книги")
                    print("4. Показать пользователей")
                    print("5. Выйти")

                    choice = input("Выбор: ")
                    if choice == "1":
                        self.add_book()
                    elif choice == "2":
                        self.remove_book()
                    elif choice == "3":
                        self.show_all_books()
                    elif choice == "4":
                        self.show_all_users()
                    elif choice == "5":
                        self.logout()
                    else:
                        print("Неверный выбор")

                elif isinstance(self.__current_user, User):
                    print("1. Доступные книги")
                    print("2. Взять книгу")
                    print("3. Вернуть книгу")
                    print("4. Мои книги")
                    print("5. Выйти")

                    choice = input("Выбор: ")
                    if choice == "1":
                        self.show_available_books()
                    elif choice == "2":
                        self.take_book()
                    elif choice == "3":
                        self.return_book()
                    elif choice == "4":
                        self.show_my_books()
                    elif choice == "5":
                        self.logout()
                    else:
                        print("Неверный выбор")

            else:
                print("1. Войти как Библиотекарь")
                print("2. Войти как Пользователь")
                print("3. Выход из программы")

                choice = input("Выбор: ")
                if choice == "1":
                    name = input("Логин: ")
                    password = input("Пароль: ")
                    self.login_admin(name, password)
                elif choice == "2":
                    name = input("Ваше имя: ")
                    self.login_user(name)
                elif choice == "3":
                    self.__save_data()
                    print("До свидания!")
                    break
                else:
                    print("Неверный выбор")


Library().run()

